# Database — Neon Serverless Postgres (https://neon.tech)
DATABASE_URL="postgresql://..."

# Auth — Better Auth
BETTER_AUTH_SECRET="....."
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OAuth providers (optional — only needed if using social login)
GITHUB_CLIENT_ID="....."
GITHUB_CLIENT_SECRET="....."
GOOGLE_CLIENT_ID="....."
GOOGLE_CLIENT_SECRET="....."

# Stream Video + Chat (https://getstream.io)
# NOTE: Stream does not work in the UAE — use a VPN set to an EU location
NEXT_PUBLIC_STREAM_VIDEO_API_KEY="....."
STREAM_VIDEO_SECRET_KEY="....."
NEXT_PUBLIC_STREAM_CHAT_API_KEY="....."
STREAM_CHAT_SECRET_KEY="....."

# OpenAI — embeddings, guardrails, real-time AI agent, and all chatbot agents
OPENAI_SECRET_KEY="sk-proj-...."
OPENAI_API_KEY="sk-proj-...."

# Inngest — background job processing (transcript pipeline)
INNGEST_EVENT_KEY="....."
INNGEST_SIGNING_KEY="....."

# Ngrok — required for the AI agent (real-time call) and Inngest webhooks to work locally
# Run: ngrok http 3000  (or with a static domain: ngrok http --url=your-domain.ngrok-free.app 3000)
# Then set your Stream webhook URL and Inngest sync URL to your ngrok forwarding URL
Webhook="ngrok http 3000"
